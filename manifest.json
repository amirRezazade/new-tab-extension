{
  "manifest_version": 3,
  "name": "Nova Tab",
  "version": "1.0.0",
  "description": "صفحه تب جدید سفارشی من",

  "permissions": ["storage", "tabs", "windows"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add to Nova"
  },
  "host_permissions": ["https://api.open-meteo.com/*", "https://geocoding-api.open-meteo.com/*", "https://icons.duckduckgo.com/*", "https://*/*", "http://*/*"],
  "icons": {
    "16": "icons/icon.18.png",
    "48": "icons/icon.48.png",
    "128": "icons/icon.96.png"
  }
}
